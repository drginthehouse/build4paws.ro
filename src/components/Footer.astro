---
import Container from "./Container.astro";

const year = new Date().getFullYear();
---
<footer class="bg-navy text-white pt-16 pb-8">
  <Container>
    <div class="grid gap-12 md:grid-cols-4">
      <div class="md:col-span-2">
        <img src="/logo/logo-horizontal-white.svg" alt="Build 4 Paws" class="h-9 w-auto mb-4" />
        <p class="text-slate-300 max-w-md">
          Construim infrastructura software care conectează ONG-uri, cetățeni, veterinari și autorități pentru bunăstarea animalelor.
        </p>
      </div>

      <div>
        <h4 class="text-white text-base font-medium mb-4 font-[var(--font-sans)]">Navigare</h4>
        <ul class="space-y-2">
          <li><a href="/despre" class="text-slate-300 hover:text-orange no-underline">Despre</a></li>
          <li><a href="/proiecte" class="text-slate-300 hover:text-orange no-underline">Proiecte</a></li>
          <li><a href="/contact" class="text-slate-300 hover:text-orange no-underline">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white text-base font-medium mb-4 font-[var(--font-sans)]">Contact</h4>
        <ul class="space-y-2">
          <li>
            <a href="mailto:contact@build4paws.ro" class="text-slate-300 hover:text-orange no-underline">
              contact@build4paws.ro
            </a>
          </li>
          <li>
            <a href="https://github.com/Build4Paws" target="_blank" rel="noopener" class="text-slate-300 hover:text-orange no-underline">
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between gap-4 text-sm text-slate-300">
      <div>
        <p>© {year} Asociația Build 4 Paws</p>
        <p class="mt-1">OG 26/2000 · Încheiere nr. 217/2026 · Judecătoria Alba Iulia</p>
      </div>
      <div class="flex gap-6">
        <a href="/privacy" class="text-slate-300 hover:text-orange no-underline">Politica de confidențialitate</a>
        <a href="/termeni" class="text-slate-300 hover:text-orange no-underline">Termeni</a>
      </div>
    </div>
  </Container>
</footer>
