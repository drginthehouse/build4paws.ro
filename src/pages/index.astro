---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/Container.astro";
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";

const pillars = [
  {
    icon: "lucide:users",
    title: "ONG-uri",
    text: "Instrumente digitale care eficientizează activitatea și scot ONG-urile din Excel-uri și grupuri de WhatsApp.",
  },
  {
    icon: "lucide:heart-handshake",
    title: "Cetățeni",
    text: "Acces simplu la adopție, sterilizare, raportarea abuzurilor. Fără birocrație, fără apeluri la zeci de numere.",
  },
  {
    icon: "lucide:stethoscope",
    title: "Veterinari",
    text: "Management de cazuri și punte directă cu ONG-urile. Mai puțin timp la telefon, mai mult pe pacient.",
  },
  {
    icon: "lucide:landmark",
    title: "Autorități",
    text: "Date și civic tech pentru primării, DSVSA și legiuitor. Politici publice fundamentate pe evidențe, nu pe intuiție.",
  },
];

const values = [
  {
    icon: "lucide:hammer",
    title: "Architecting Solutions",
    quote: "Stop patching, start building.",
    text: "Nu mai cârpim un sistem care nu funcționează. Construim infrastructura pe care sectorul o merită.",
  },
  {
    icon: "lucide:network",
    title: "Radical Collaboration",
    quote: "Innovation happens at the intersection.",
    text: "Sectorul e fragmentat — noi suntem liantul. Aducem toți cei 4 piloni la aceeași masă.",
  },
  {
    icon: "lucide:chart-line",
    title: "Data-Driven Compassion",
    quote: "Empathy powered by evidence.",
    text: "Inima unui salvator, mintea unui data scientist. Fiecare efort duce la o îmbunătățire măsurabilă.",
  },
  {
    icon: "lucide:zap",
    title: "Digital-First Simplicity",
    quote: "Complex tech, simple experiences.",
    text: "Tăiem birocrația. Instrumentele noastre sunt intuitive, accesibile și rapide — pentru developeri și pentru cei care adoptă prima dată.",
  },
];
---
<BaseLayout>
  <!-- Hero -->
  <Section tone="navy" class="!pt-28 md:!pt-36 !pb-24 md:!pb-32">
    <Container>
      <div class="max-w-3xl">
        <p class="text-orange font-medium mb-6 uppercase tracking-wider text-sm">
          Tech NGO · Animal Welfare Infrastructure
        </p>
        <h1 class="text-h1 !text-white mb-6">
          Infrastructura software care schimbă protecția animalelor.
        </h1>
        <p class="text-xl text-slate-300 mb-10 leading-relaxed">
          Conectăm ONG-uri, cetățeni, veterinari și autorități într-un ecosistem digital.
          Pornim de la durerea reală din teren — nu de la idei strălucite.
        </p>
        <div class="flex flex-wrap gap-4">
          <Button href="/proiecte" variant="primary">
            Vezi proiectele
            <Icon name="lucide:arrow-right" class="w-5 h-5" />
          </Button>
          <Button href="/despre" variant="ghost" class="!border-white !text-white hover:!bg-white hover:!text-navy">
            Cum lucrăm
          </Button>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Problema -->
  <Section tone="default">
    <Container>
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div>
          <p class="text-orange font-medium mb-4 uppercase tracking-wider text-sm">Problema</p>
          <h2 class="text-h2 mb-6">Sectorul e fragmentat. Animalele plătesc costul.</h2>
        </div>
        <div class="space-y-6 text-lg text-slate-600 leading-relaxed">
          <p>
            ONG-uri supraîncărcate care țin totul în Excel-uri.
            Veterinari care nu au cum să colaboreze sistematic cu organizațiile.
            Cetățeni care nu știu pe unde să o ia când vor să adopte sau să raporteze un abuz.
            Autorități care iau decizii fără date.
          </p>
          <p>
            Patchuim de ani de zile un sistem care nu funcționează.
            <strong class="text-navy">Build 4 Paws construiește — nu patchează.</strong>
          </p>
        </div>
      </div>
    </Container>
  </Section>

  <!-- Cei 4 piloni -->
  <Section tone="muted">
    <Container>
      <div class="mb-16 max-w-3xl">
        <p class="text-orange font-medium mb-4 uppercase tracking-wider text-sm">Cei 4 piloni</p>
        <h2 class="text-h2 mb-6">Construim pentru toți actorii din ecosistem.</h2>
        <p class="text-lg text-slate-600 leading-relaxed">
          Animalele sunt fericite când toți actorii stau la aceeași masă.
          Orice proiect Build 4 Paws trebuie să servească cel puțin unul dintre acești piloni —
          iar cele mai puternice îi conectează pe toți.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {pillars.map((p) => (
          <Card class="!p-8 h-full flex flex-col">
            <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-5">
              <Icon name={p.icon} class="w-6 h-6 text-white" />
            </div>
            <h3 class="text-h4 mb-3">{p.title}</h3>
            <p class="text-slate-600 leading-relaxed">{p.text}</p>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Valori / Brand values -->
  <Section tone="navy">
    <Container>
      <div class="mb-16 max-w-3xl">
        <p class="text-orange font-medium mb-4 uppercase tracking-wider text-sm">Cum gândim</p>
        <h2 class="text-h2 !text-white mb-6">Patru principii. Fără fluff.</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-2">
        {values.map((v) => (
          <div class="border-l-2 border-orange pl-6">
            <div class="flex items-center gap-3 mb-3">
              <Icon name={v.icon} class="w-6 h-6 text-orange" />
              <h3 class="text-h4 !text-white !mb-0">{v.title}</h3>
            </div>
            <p class="text-orange italic mb-3">"{v.quote}"</p>
            <p class="text-slate-300 leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </Container>
  </Section>

  <!-- Proiecte teaser -->
  <Section tone="default">
    <Container>
      <div class="mb-12 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div class="max-w-2xl">
          <p class="text-orange font-medium mb-4 uppercase tracking-wider text-sm">Proiecte</p>
          <h2 class="text-h2 mb-4">Ce construim acum.</h2>
          <p class="text-lg text-slate-600 leading-relaxed">
            Nu ținem planuri secrete. Proiectele, research-ul și deciziile sunt publice.
          </p>
        </div>
        <Button href="/proiecte" variant="ghost">
          Toate proiectele
          <Icon name="lucide:arrow-right" class="w-5 h-5" />
        </Button>
      </div>

      <Card class="!p-0 overflow-hidden">
        <div class="grid md:grid-cols-5">
          <div class="md:col-span-2 bg-navy text-white p-8 md:p-10 flex flex-col justify-between">
            <div>
              <span class="inline-flex items-center gap-2 text-xs uppercase tracking-wider text-orange font-medium mb-4">
                <span class="w-2 h-2 rounded-full bg-orange"></span>
                În explorare
              </span>
              <h3 class="text-h3 !text-white mb-3">Sterilizare Gratuită</h3>
              <p class="text-slate-300 leading-relaxed">
                Agregator național al campaniilor de sterilizare gratuite + notificări pentru cetățeni.
              </p>
            </div>
            <div class="mt-8 pt-8 border-t border-white/10 text-sm text-slate-300">
              Quick win pentru vizibilitate. Research în teren.
            </div>
          </div>
          <div class="md:col-span-3 p-8 md:p-10">
            <h4 class="text-slate-600 uppercase text-xs tracking-wider font-medium mb-3">Problema</h4>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Zeci de ONG-uri organizează campanii de sterilizare gratuite separat, fără coordonare.
              Iubitorii de animale nu știu când și unde au loc. Se pierd mii de sterilizări potențiale.
            </p>
            <h4 class="text-slate-600 uppercase text-xs tracking-wider font-medium mb-3">Abordare</h4>
            <p class="text-slate-600 leading-relaxed">
              Un singur loc unde ONG-urile publică campaniile și cetățenii se abonează la notificări pentru orașul lor.
              Simplu, rapid, livrat mic și des.
            </p>
          </div>
        </div>
      </Card>
    </Container>
  </Section>

  <!-- CTA final -->
  <Section tone="muted">
    <Container>
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-h2 mb-6">Ai o problemă reală din teren?</h2>
        <p class="text-lg text-slate-600 mb-8 leading-relaxed">
          Nu decidem ce construim pe baza entuziasmului nostru.
          Întrebăm, ascultăm, verificăm. Dacă ești ONG, veterinar sau lucrezi cu o autoritate —
          spune-ne unde doare.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <Button href="/contact" variant="primary">
            Contactează-ne
            <Icon name="lucide:arrow-right" class="w-5 h-5" />
          </Button>
          <Button href="https://github.com/Build4Paws" target="_blank" rel="noopener" variant="ghost">
            <Icon name="lucide:github" class="w-5 h-5" />
            Vezi pe GitHub
          </Button>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
